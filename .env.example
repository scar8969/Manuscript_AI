# Server
PORT=3000
NODE_ENV=development

# OpenRouter API (free models available at openrouter.ai)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Alternative: Use OpenAI directly
# OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT Secrets (generate strong random strings)
ACCESS_TOKEN_SECRET=your-very-long-random-access-secret-key-here
REFRESH_TOKEN_SECRET=your-very-long-random-refresh-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/manuscript_ai

# CORS (comma-separated origins, for production)
ALLOWED_ORIGIN=http://localhost:5173

# Vercel deployment (URLs of self-hosted backend for compile/scrape)
COMPILE_SERVICE_URL=
SCRAPE_SERVICE_URL=

# LaTeX Compilation Limits
MAX_INPUT_SIZE=1000000
TEMP_DIR=./temp
CLEANUP_INTERVAL_MS=1800000
TEMP_MAX_AGE_MS=3600000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
